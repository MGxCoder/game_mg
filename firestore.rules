rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - each user can only read/write their own data
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Leaderboard - anyone can read, only authenticated users can write their own entry
    match /leaderboard/{entryId} {
      allow read: if true;
      allow create: if request.auth != null 
        && request.auth.uid == entryId
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null 
        && request.auth.uid == entryId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.score >= resource.data.score; // Can only increase score
    }
    
    // Global stats - anyone can read, authenticated users can update
    match /globalStats/{statId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
